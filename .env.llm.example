LLM_DEFAULT_PROVIDER=local

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat

KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_CHAT_MODEL=moonshot-v1-8k

RETRIEVAL_EMBEDDING_BACKEND=sentence_transformers
RETRIEVAL_EMBEDDING_MODEL=BAAI/bge-m3
RETRIEVAL_RERANKER_ENABLED=true
RETRIEVAL_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_ENABLED=true
REDIS_CACHE_TTL_SECONDS=21600
OCR_ENABLED=true
OCR_BACKEND=rapidocr
